-- assuming bonus percentage is given 
-- Scenario 2: The bank wants to implement a bonus scheme for employees based on their performance.
-- Question: Write a stored procedure UpdateEmployeeBonus that updates the salary of employees in a given department by adding a bonus percentage passed as a parameter.


CREATE OR REPLACE PROCEDURE updateEmployeeBonus(DEPT IN VARCHAR2, B IN NUMBER)
IS 
BEGIN 
 FOR EB IN (SELECT * FROM Employee)
 LOOP
 IF EB.Department = DEPT THEN
   UPDATE Employee SET salary = salary + (Salary * (B/100))
   WHERE EmployeeID = EB.EmployeeID;
 END IF;
 END LOOP;
END;
\

