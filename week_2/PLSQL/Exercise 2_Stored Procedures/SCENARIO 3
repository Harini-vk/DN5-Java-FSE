CREATE OR REPLACE PROCEDURE TransferFunds(
   fromAccount IN NUMBER,
   toAccount   IN NUMBER,
   amount      IN NUMBER
)
IS
    fromacc_bal NUMBER;
BEGIN

    SELECT Balance
    INTO fromacc_bal
    FROM Account
    WHERE AccountID = fromAccount;

    IF fromacc_bal >= p_amount THEN
        UPDATE Account
        SET Balance = Balance - amount
        WHERE AccountID = fromAccount;
        UPDATE Account
        SET Balance = Balance + amount
        WHERE AccountID = toAccount;

        DBMS_OUTPUT.PUT_LINE('Transfer is successful');
    ELSE
        DBMS_OUTPUT.PUT_LINE('Insufficient Balance');
    END IF;
END;
